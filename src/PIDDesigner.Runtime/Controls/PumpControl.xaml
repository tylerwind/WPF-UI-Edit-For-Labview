<UserControl x:Class="PIDDesigner.Runtime.Controls.PumpControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="80" Height="80">
    <Grid>
        <Image Source="/PIDDesigner.Runtime;component/Resources/pump.png" Stretch="Uniform" />
        
        <!-- Status Indicator (Overlay) -->
        <Ellipse x:Name="RunningIndicator" Width="8" Height="8" Fill="Lime" 
                 HorizontalAlignment="Right" VerticalAlignment="Top" 
                 Margin="0,5,5,0" Visibility="Collapsed">
            <Ellipse.Effect>
                <BlurEffect Radius="4" />
            </Ellipse.Effect>
        </Ellipse>
    </Grid>
</UserControl>
