<UserControl x:Class="PIDDesigner.Runtime.Controls.ValveControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="60" Height="60">
    <Grid>
        <Image Source="/PIDDesigner.Runtime;component/Resources/valve.png" Stretch="Uniform" />
        
        <!-- Status Indicator -->
        <Ellipse x:Name="RunningIndicator" Width="8" Height="8" Fill="Lime" 
                 HorizontalAlignment="Right" VerticalAlignment="Top" 
                 Margin="0,5,5,0" Visibility="Collapsed">
            <Ellipse.Effect>
                <BlurEffect Radius="4" />
            </Ellipse.Effect>
        </Ellipse>
    </Grid>
</UserControl>
